{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pomodoro-desktop",
  "version": "0.1.1",
  "identifier": "com.zeus.pomodoro-desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Pomodoro Pro",
        "width": 450,
        "height": 650,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 350,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
